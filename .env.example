# YouTube Content Summarizer Bot - Environment Configuration

# Required: Telegram bot token from @BotFather
BOT_TOKEN=your_telegram_bot_token_here

# Required: Google Gemini API key from Google AI Studio
GEMINI_API_KEY=your_gemini_api_key_here

# Get from Cloudflare WARP mobile app if you have a WARP+ subscription
# WARP_LICENSE_KEY=your_warp_plus_license_key_here

# Optional: Custom proxy URL (auto-configured with WARP by default)
# PROXY_URL=socks5://warp:1080

# Optional: WARP configuration
# WARP_SLEEP=2
